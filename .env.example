# -----------------------------------------------------------
# Mistral AI – required
# Get your key at https://console.mistral.ai/api-keys/
# -----------------------------------------------------------
MISTRAL_API_KEY=

# -----------------------------------------------------------
# Mistral model override – optional
# Recommended for UI screenshots / image-to-HTML: pixtral-large-latest
# -----------------------------------------------------------
# MISTRAL_MODEL=pixtral-large-latest

# -----------------------------------------------------------
# Optional tuning for production timeouts / response size
# -----------------------------------------------------------
# MISTRAL_MAX_TOKENS=3500
# MISTRAL_TIMEOUT_MS=55000
