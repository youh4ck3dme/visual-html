# Client-visible feature flag. Safe to expose; Vite injects VITE_* into browser JS.
VITE_MISTRAL_SERVER_PROXY=true

# PNGtoHTML screenshot tool (sibling app in monorepo)
VITE_PNGTOHTML_URL=http://localhost:8080

# Server-only Vercel environment variables. Never prefix provider secrets with VITE_.
MISTRAL_API_KEY_1=
MISTRAL_API_KEY_2=
MISTRAL_MODEL=mistral-large-latest
VIBE_SERVICE_TOKEN=
VIBE_ALLOW_DEV_SERVICE_TOKEN=false
VIBE_RATE_LIMIT_WINDOW_MS=60000
VIBE_RATE_LIMIT_MAX=20
VIBE_MAX_BODY_BYTES=65536
