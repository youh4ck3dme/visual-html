# Local development template (safe to copy)
# Do not paste VERCEL_OIDC_TOKEN or any runtime-issued temporary tokens here.

# Required (at least one Mistral key)
MISTRAL_API_KEY=
# Failover when primary is rate-limited or out of quota
MISTRAL_API_KEY_FALLBACK=
# Optional ordered pool: key1,key2,key3
# MISTRAL_API_KEYS=

# Optional parallel split (each pipeline phase prefers its own key, then falls back to the global pool)
# MISTRAL_OCR_API_KEY=
# MISTRAL_OCR_API_KEY_FALLBACK=
# MISTRAL_OCR_API_KEYS=
# MISTRAL_CHAT_API_KEY=
# MISTRAL_CHAT_API_KEY_FALLBACK=
# MISTRAL_CHAT_API_KEYS=

BLOB_READ_WRITE_TOKEN=

# Optional model overrides
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_MODEL=pixtral-large-latest
# VibeCraft builder (/builder) server-side model; falls back to MISTRAL_MODEL
MISTRAL_BUILDER_MODEL=mistral-large-latest

# VibeCraft builder BYOK (browser localStorage — set in /builder → Settings, not here):
#   builder_mistral_api_key_1, builder_mistral_api_key_2, builder_mistral_model
# Without BYOK keys the builder uses server MISTRAL_API_KEY or Demo Mode (templates only).

# Optional tuning
MISTRAL_MAX_TOKENS=3000
MISTRAL_TIMEOUT_MS=55000

# Rate limiting (per-IP, backed by Upstash Redis). Required in production;
# if unset, rate limiting is disabled (fail-open) and a warning is logged.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional overrides
RATE_LIMIT_BURST=5
RATE_LIMIT_DAILY=100
