# -----------------------------------------------------------
# Mistral AI – required (screenshot → HTML pipeline)
# Get your key at https://console.mistral.ai/api-keys/
# -----------------------------------------------------------
MISTRAL_API_KEY=YOUR_NEW_MISTRAL_API_KEY

# -----------------------------------------------------------
# OCR model for screenshot text/structure extraction
# -----------------------------------------------------------
# MISTRAL_OCR_MODEL=mistral-ocr-latest

# -----------------------------------------------------------
# Synthesis/refine model for HTML generation (screenshot → HTML)
# -----------------------------------------------------------
# MISTRAL_MODEL=mistral-medium-3.5

# -----------------------------------------------------------
# VibeCraft builder (/builder) – server-side AI model override
# Falls back to MISTRAL_MODEL, then mistral-large-latest
# -----------------------------------------------------------
# MISTRAL_BUILDER_MODEL=mistral-large-latest

# -----------------------------------------------------------
# Required for OCR upload staging on Vercel Blob
# -----------------------------------------------------------
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# -----------------------------------------------------------
# Rate limiting (required in production)
# -----------------------------------------------------------
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx
# RATE_LIMIT_BURST=5
# RATE_LIMIT_DAILY=100

# -----------------------------------------------------------
# Optional tuning for production timeouts / response size
# -----------------------------------------------------------
# MISTRAL_MAX_TOKENS=3500
# MISTRAL_TIMEOUT_MS=55000

# -----------------------------------------------------------
# VibeCraft builder BYOK (browser localStorage, not server env)
# Configure in-app: /builder → Settings (gear icon)
#   builder_mistral_api_key_1  – primary Mistral key
#   builder_mistral_api_key_2  – failover key
#   builder_mistral_model        – model override (default: mistral-large-latest)
# BYOK is optional. Without browser keys, /builder uses server MISTRAL_API_KEY
# (same key as screenshot → HTML). Demo Mode applies only when both are missing.