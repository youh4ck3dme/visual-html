# Local development template (safe to copy)
# Do not paste VERCEL_OIDC_TOKEN or any runtime-issued temporary tokens here.

# Required
MISTRAL_API_KEY=
BLOB_READ_WRITE_TOKEN=

# Optional model overrides
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_MODEL=pixtral-large-latest

# Optional tuning
MISTRAL_MAX_TOKENS=3500
MISTRAL_TIMEOUT_MS=55000

# Rate limiting (per-IP, backed by Upstash Redis). Required in production;
# if unset, rate limiting is disabled (fail-open) and a warning is logged.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional overrides
RATE_LIMIT_BURST=5
RATE_LIMIT_DAILY=100
